# ThingsBoard IoT Platform
TB_USERNAME=your_thingsboard_email@example.com
TB_PASSWORD=your_thingsboard_password
TB_DEVICE_ACCESS_TOKEN=your_device_access_token
TB_DEVICE_ID=your_device_uuid
TB_SERVER_URL=192.168.x.x:8080

# PLC / Modbus Network
PLC_URL_PHONE=192.168.x.x
PLC_URL_HOME=192.168.x.x
PLC_URL_ETHERNET=192.168.x.x
PLC_URL_PLC=192.168.x.x

# PLC subnet and node list (used by pressureprogram and plc_alarm_tests.py)
PLC_SUBNET=192.168.x
PLC_NODES=1,2,3
PLC_TEST_NODES=1

# Gateway / Time Sync
GATEWAY_URL=http://192.168.x.x
GATEWAY_API_PORT=5001

# Application
SETTINGS_PASSWORD=changeme
